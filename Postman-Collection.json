{
  "info": {
    "name": "Subscription Lifecycle Engine",
    "description": "Production-grade Subscription Management API with state machine, grace periods, and automated scheduling.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Plans",
      "item": [
        {
          "name": "List Plans",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "// Save first plan ID for other requests",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data.length > 0) {",
                  "    pm.environment.set('plan_id', jsonData.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/plans",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans"
              ]
            },
            "description": "Get all active subscription plans"
          },
          "response": []
        },
        {
          "name": "Create Plan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('Plan has required fields', function () {",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.expect(jsonData.data).to.have.property('name');",
                  "    pm.expect(jsonData.data).to.have.property('is_active', true);",
                  "});",
                  "",
                  "pm.environment.set('created_plan_id', jsonData.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Professional\",\n  \"description\": \"For growing teams\",\n  \"features\": [\"Advanced analytics\", \"API access\", \"Priority support\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plans",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans"
              ]
            },
            "description": "Create a new subscription plan"
          },
          "response": []
        },
        {
          "name": "Get Plan",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/plans/{{plan_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans",
                "{{plan_id}}"
              ]
            },
            "description": "Get plan details"
          },
          "response": []
        },
        {
          "name": "Add Billing Cycle",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('billing_cycle_id', jsonData.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cycle_type\": \"monthly\",\n  \"duration_in_days\": 30,\n  \"display_name\": \"Monthly\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plans/{{plan_id}}/billing-cycles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans",
                "{{plan_id}}",
                "billing-cycles"
              ]
            },
            "description": "Add a billing cycle to a plan"
          },
          "response": []
        },
        {
          "name": "Add Pricing (USD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('plan_price_id', jsonData.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_billing_cycle_id\": \"{{billing_cycle_id}}\",\n  \"currency\": \"USD\",\n  \"price\": 99.99\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plans/{{plan_id}}/pricing",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans",
                "{{plan_id}}",
                "pricing"
              ]
            },
            "description": "Add USD pricing for a billing cycle"
          },
          "response": []
        },
        {
          "name": "Add Pricing (AED)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_billing_cycle_id\": \"{{billing_cycle_id}}\",\n  \"currency\": \"AED\",\n  \"price\": 367.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plans/{{plan_id}}/pricing",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans",
                "{{plan_id}}",
                "pricing"
              ]
            },
            "description": "Add AED pricing for a billing cycle"
          },
          "response": []
        },
        {
          "name": "Get Plan Pricing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/plans/{{plan_id}}/pricing?currency=USD&cycle=monthly",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plans",
                "{{plan_id}}",
                "pricing"
              ],
              "query": [
                {
                  "key": "currency",
                  "value": "USD"
                },
                {
                  "key": "cycle",
                  "value": "monthly"
                }
              ]
            },
            "description": "Get pricing for a specific currency and billing cycle"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Create Subscription (with Trial)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('Subscription has required fields', function () {",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.expect(jsonData.data).to.have.property('status', 'trialing');",
                  "    pm.expect(jsonData.data).to.have.property('trial_ends_at');",
                  "});",
                  "",
                  "pm.environment.set('subscription_id', jsonData.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_id\": \"{{plan_id}}\",\n  \"plan_billing_cycle_id\": \"{{billing_cycle_id}}\",\n  \"currency\": \"USD\",\n  \"trial_period_days\": 14\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions"
              ]
            },
            "description": "Create a new subscription with 14-day trial"
          },
          "response": []
        },
        {
          "name": "Create Subscription (No Trial)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_id\": \"{{plan_id}}\",\n  \"plan_billing_cycle_id\": \"{{billing_cycle_id}}\",\n  \"currency\": \"USD\",\n  \"trial_period_days\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions"
              ]
            },
            "description": "Create a new subscription without trial (starts active immediately)"
          },
          "response": []
        },
        {
          "name": "List My Subscriptions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions?page=1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            },
            "description": "Get all subscriptions for authenticated user"
          },
          "response": []
        },
        {
          "name": "Get Subscription Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions/{{subscription_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscription_id}}"
              ]
            },
            "description": "Get detailed subscription information"
          },
          "response": []
        },
        {
          "name": "Get Subscription Status Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions/{{subscription_id}}/status-info",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscription_id}}",
                "status-info"
              ]
            },
            "description": "Get subscription status with transition information"
          },
          "response": []
        },
        {
          "name": "Get Subscription History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions/{{subscription_id}}/history",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscription_id}}",
                "history"
              ]
            },
            "description": "Get audit trail of all state changes for a subscription"
          },
          "response": []
        },
        {
          "name": "Cancel Subscription",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"User requested cancellation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions/{{subscription_id}}/cancel",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscription_id}}",
                "cancel"
              ]
            },
            "description": "Cancel an active or trialing subscription"
          },
          "response": []
        },
        {
          "name": "Change Billing Cycle",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_billing_cycle_id\": \"{{billing_cycle_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions/{{subscription_id}}/billing-cycle",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "subscriptions",
                "{{subscription_id}}",
                "billing-cycle"
              ]
            },
            "description": "Change subscription billing cycle (e.g., monthly to yearly)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Webhook: Payment Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": "{{webhook_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscription_id\": \"{{subscription_id}}\",\n  \"amount\": 99.99,\n  \"currency\": \"USD\",\n  \"status\": \"completed\",\n  \"transaction_id\": \"txn_1234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/webhooks/payment-success",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "webhooks",
                "payment-success"
              ]
            },
            "description": "Handle successful payment from payment provider"
          },
          "response": []
        },
        {
          "name": "Webhook: Payment Failed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": "{{webhook_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscription_id\": \"{{subscription_id}}\",\n  \"amount\": 99.99,\n  \"currency\": \"USD\",\n  \"reason\": \"card_declined\",\n  \"error_code\": \"card_declined\",\n  \"error_message\": \"Your card was declined.\",\n  \"transaction_id\": \"txn_1234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/webhooks/payment-failed",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "webhooks",
                "payment-failed"
              ]
            },
            "description": "Handle failed payment - subscription enters grace period"
          },
          "response": []
        },
        {
          "name": "Webhook: Payment Recovered",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": "{{webhook_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscription_id\": \"{{subscription_id}}\",\n  \"amount\": 99.99,\n  \"currency\": \"USD\",\n  \"recovery_type\": \"retry\",\n  \"transaction_id\": \"txn_0987654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/webhooks/payment-recovered",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "webhooks",
                "payment-recovered"
              ]
            },
            "description": "Handle payment recovery during grace period"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Scheduler Commands",
      "item": [
        {
          "name": "Expire Trials (Dry-Run)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dry_run\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/commands/expire-trials",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "commands",
                "expire-trials"
              ]
            },
            "description": "Test trial expiry logic without making changes (runs daily at 00:01 UTC)"
          },
          "response": []
        },
        {
          "name": "Process Grace Period (Dry-Run)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dry_run\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/commands/process-grace-period",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "commands",
                "process-grace-period"
              ]
            },
            "description": "Test grace period expiry logic without making changes (runs daily at 01:00 UTC)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "api_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "plan_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "billing_cycle_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "plan_price_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "subscription_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "webhook_signature",
      "value": "your-webhook-signature-here",
      "type": "string"
    }
  ]
}
